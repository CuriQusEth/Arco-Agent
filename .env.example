# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Circle Developer-Controlled Wallets
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# Mnemonic Protocol (verifiable memory) — server-side only, never shipped to the browser
MNEMONIC_MCP_URL="https://mcp.mnemonik.xyz/mcp"   # or http://localhost:3000/mcp for a local mnemonic-mcp
MNEMONIC_JWT=                                       # OAuth bearer for the operator identity (omit for local mode)
MNEMONIC_DEFAULT_MODE="local"                      # local (free, offline) | participate (anchored on Solana/Arweave)
MNEMONIC_DEFAULT_VISIBILITY="public"               # participate only
